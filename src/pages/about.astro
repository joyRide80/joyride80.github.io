---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About — joy·object" description="Joy is a Danish/Thai product designer and creative technologist living in Oslo with 17+ years of experience.">
  <div class="about">
    <!-- Header -->
    <header class="project__header" style="display:flex;justify-content:space-between;align-items:flex-start;padding:20px var(--page-padding);">
      <a href="/" class="type-logo home__logo" style="text-decoration:none;color:var(--gray-900);">
        joy<span class="home__logo-dot"></span>object
      </a>
    </header>

    <!-- Navigation -->
    <nav class="home__nav" style="position:absolute;top:80px;left:26px;display:flex;flex-direction:column;gap:8px;z-index:10;">
      <a href="/" class="btn-light">Work</a>
      <a href="/about" class="btn-light is-active">
        About
        <span style="display:inline-flex;align-items:center;justify-content:center;width:20px;height:20px;">
          <span style="width:4px;height:4px;background:var(--gray-900);border-radius:50%;display:block;"></span>
        </span>
      </a>
    </nav>

    <!-- Content -->
    <div class="about__content">
      <!-- Left: Portrait -->
      <div class="about__portrait-wrap">
        <img
          src="/images/about/joy-portrait.jpg"
          alt="Joy working at desk"
          class="about__portrait"
          width="400"
          height="500"
        />
      </div>

      <!-- Right: Text -->
      <div class="about__right">
        <!-- ASCII Art -->
        <div class="about__ascii type-ascii">
{`      ___           ___           ___       ___       ___     
     /\\__\\         /\\  \\         /\\__\\     /\\__\\     /\\  \\    
    /:/  /        /::\\  \\       /:/  /    /:/  /    /::\\  \\   
   /:/__/        /:/\\:\\  \\     /:/  /    /:/  /    /:/\\:\\  \\  
  /::\\  \\ ___   /::\\~\\:\\  \\   /:/  /    /:/  /    /:/  \\:\\  \\ 
 /:/\\:\\  /\\__\\ /:/\\:\\ \\:\\__\\ /:/__/    /:/__/    /:/__/ \\:\\__\\
 \\/__\\:\\/:/  / \\:\\~\\:\\ \\/__/ \\:\\  \\    \\:\\  \\    \\:\\  \\ /:/  /
      \\::/  /   \\:\\ \\:\\__\\    \\:\\  \\    \\:\\  \\    \\:\\  /:/  / 
      /:/  /     \\:\\ \\/__/     \\:\\  \\    \\:\\  \\    \\:\\/:/  /  
     /:/  /       \\:\\__\\        \\:\\__\\    \\:\\__\\    \\::/  /   
     \\/__/         \\/__/         \\/__/     \\/__/     \\/__/    `}
        </div>

        <!-- Intro -->
        <p class="about__intro">
          My name is Joy, a Danish/Thai living in Oslo.
          I'm a product designer and creative
          technologist with 17+ years of experience, and
          lately most of my energy goes into designing
          AI-native products, figuring out how to make
          generative systems feel intuitive, playful,
          and genuinely useful.
        </p>

        <!-- Body -->
        <div class="about__body">
          <p>
            I'm currently at <a href="http://megalearn.se/" target="_blank" rel="noopener">Megalearn</a>
            (the ed-tech startup I co-founded), where I'm leading the design and development of
            a browser-based multiplayer <a href="http://megalearn.ai/" target="_blank" rel="noopener">educational game</a>
            powered by generative AI and Three.js. I also work as design lead at
            <a href="http://skalar.no/" target="_blank" rel="noopener">Skalar</a>, where I designed
            an AI-driven tool helping small businesses in Norway manage their carbon emissions.
          </p>

          <p>
            Before that, I spent 4 years as a senior product designer at
            <a href="http://kahoot.com/" target="_blank" rel="noopener">Kahoot!</a>, the game-based
            learning platform played by over a billion players yearly. And before Oslo, while living in
            Copenhagen, I was a senior product designer at Falcon.io (now
            <a href="https://www.brandwatch.com/" target="_blank" rel="noopener">Brandwatch</a>), a social
            media management tool, Graduateland (now
            <a href="https://www.jobteaser.com/en" target="_blank" rel="noopener">Jobteaser</a>), a leading
            job portal in Europe, and Leo Innovation Lab, a health tech incubator. I also spent almost 5
            years at <a href="https://podio.com/" target="_blank" rel="noopener">Podio</a> designing an
            online productivity tool, before it was acquired by
            <a href="https://www.citrix.com/" target="_blank" rel="noopener">Citrix</a>.
          </p>
        </div>

        <!-- Download CV -->
        <div class="about__cv-btn">
          <a href="#" class="btn-dark">Download my CV</a>
        </div>
      </div>
    </div>

    <!-- Contact -->
    <div style="position:absolute;bottom:20px;left:var(--page-padding);z-index:10;">
      <button class="btn-light" id="btn-contact">Get in touch</button>
    </div>
  </div>

  <script src="../scripts/contact.js"></script>
</BaseLayout>
