---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(project => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const projects = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);

const currentIndex = projects.findIndex(p => p.id === project.id);
const prevProject = currentIndex > 0 ? projects[currentIndex - 1] : projects[projects.length - 1];
const nextProject = currentIndex < projects.length - 1 ? projects[currentIndex + 1] : projects[0];
const { title, headline, subtitle, year, url, tags, category, heroImages } = project.data;
---

<BaseLayout title={`${headline} — joy·object`} description={subtitle}>
  <div class="project">
    <!-- Header -->
    <header class="project__header">
      <a href="/" class="type-logo home__logo" style="text-decoration:none;color:var(--gray-900);">
        joy<span class="home__logo-dot"></span>object
      </a>
      <nav class="nav-prevnext">
        <a href={`/projects/${prevProject.slug}`} class="nav-prevnext__item">
          <svg class="nav-prevnext__arrow nav-prevnext__arrow--prev" width="20" height="20" viewBox="0 0 20 20" fill="none">
            <path d="M4 10H16M16 10L11 5M16 10L11 15" stroke="#1c1c1c" stroke-width="1.5"/>
          </svg>
          <span class="type-nav">PREV</span>
        </a>
        <a href={`/projects/${nextProject.slug}`} class="nav-prevnext__item">
          <span class="type-nav">NEXT</span>
          <svg class="nav-prevnext__arrow" width="20" height="20" viewBox="0 0 20 20" fill="none">
            <path d="M4 10H16M16 10L11 5M16 10L11 15" stroke="#1c1c1c" stroke-width="1.5"/>
          </svg>
        </a>
      </nav>
    </header>

    <!-- Title -->
    <div class="project__title-group">
      <h1 class="project__title">{headline}</h1>
      <p class="project__subtitle">{subtitle}</p>
    </div>

    <!-- Intro section -->
    <div class="project__intro">
      <div style="grid-column: 1;">
        <div class="type-tiny project__intro-label">Introduction</div>
      </div>
      <div class="project__intro-meta" style="grid-column: 3;">
        <span class="project__meta-year">{year}</span>
        {url && <span class="project__meta-url">{url}</span>}
        <span class="project__meta-tags">{tags.join(' / ')}</span>
      </div>
    </div>

    <!-- Hero image collage -->
    {heroImages && heroImages.length > 0 && (
      <div class="project__collage">
        {heroImages.map((img) => (
          <div class={`project__collage-item project__collage-item--${img.size}`}>
            <img src={img.src} alt={img.caption || ''} loading="lazy" />
          </div>
        ))}
      </div>
    )}

    <!-- Content -->
    <div class="project__content">
      <Content />
    </div>

    <!-- Footer -->
    <div class="project__footer">
      <div>
        <p class="project__footer-title">All projects/Let's talk</p>
        <button class="btn-light" id="btn-contact" style="margin-top:12px;">Get in touch</button>
      </div>
      <nav class="nav-prevnext">
        <a href={`/projects/${prevProject.slug}`} class="nav-prevnext__item">
          <svg class="nav-prevnext__arrow nav-prevnext__arrow--prev" width="20" height="20" viewBox="0 0 20 20" fill="none">
            <path d="M4 10H16M16 10L11 5M16 10L11 15" stroke="#1c1c1c" stroke-width="1.5"/>
          </svg>
          <span class="type-nav">PREV</span>
        </a>
        <a href={`/projects/${nextProject.slug}`} class="nav-prevnext__item">
          <span class="type-nav">NEXT</span>
          <svg class="nav-prevnext__arrow" width="20" height="20" viewBox="0 0 20 20" fill="none">
            <path d="M4 10H16M16 10L11 5M16 10L11 15" stroke="#1c1c1c" stroke-width="1.5"/>
          </svg>
        </a>
      </nav>
    </div>
  </div>

  <script src="../../scripts/contact.js"></script>
</BaseLayout>

<style>
  .project__content {
    max-width: 479px;
  }

  .project__content :global(h2) {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 400;
    line-height: 20px;
    letter-spacing: 0.33px;
    text-transform: uppercase;
    margin-top: 48px;
    margin-bottom: 12px;
  }

  .project__content :global(h3) {
    font-family: var(--font-display);
    font-size: 25px;
    font-weight: 400;
    line-height: 32px;
    margin-top: 32px;
    margin-bottom: 12px;
  }

  .project__content :global(p) {
    font-family: var(--font-body);
    font-size: 17px;
    line-height: 24px;
    margin-bottom: 16px;
  }

  .project__content :global(ul),
  .project__content :global(ol) {
    font-family: var(--font-body);
    font-size: 17px;
    line-height: 24px;
    margin-bottom: 16px;
    padding-left: 20px;
    list-style: disc;
  }

  .project__content :global(li) {
    margin-bottom: 8px;
  }

  .project__content :global(img) {
    width: 100%;
    border-radius: 4px;
    margin: 24px 0;
  }
</style>
