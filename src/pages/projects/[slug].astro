---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import { compareProjectCollectionEntries } from '../../lib/projectYear';
import { isVideoAssetPath } from '../../lib/media';
import { withBasePublicPath } from '../../lib/withBasePublicPath';
import { normalizeProjectCategory } from '../../lib/normalizeProjectCategory';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(project => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const projects = (await getCollection('projects')).sort(compareProjectCollectionEntries);

const currentIndex = projects.findIndex(p => p.id === project.id);
const prevProject = currentIndex > 0 ? projects[currentIndex - 1] : projects[projects.length - 1];
const nextProject = currentIndex < projects.length - 1 ? projects[currentIndex + 1] : projects[0];
const { title, headline, subtitle, year, url, tags, category, introduction } = project.data;
const displayCategory = normalizeProjectCategory(category);
const urlTrimmed = url?.trim() ?? '';
const urlHref =
  urlTrimmed &&
  (/^https?:\/\//i.test(urlTrimmed) ? urlTrimmed : `https://${urlTrimmed.replace(/^\/+/, '')}`);
const baseUrl = import.meta.env.BASE_URL;
const heroImages =
  project.data.heroImages?.map((img) => ({
    ...img,
    src: img.src ? (withBasePublicPath(img.src, baseUrl) ?? img.src) : undefined,
    overlayVideo: img.overlayVideo ? (withBasePublicPath(img.overlayVideo, baseUrl) ?? img.overlayVideo) : undefined,
    splitImages: img.splitImages?.map(
      (u) => withBasePublicPath(u, baseUrl) ?? u,
    ),
    cycleImages: img.cycleImages?.map(
      (u) => withBasePublicPath(u, baseUrl) ?? u,
    ),
  })) ?? [];

/** All non-video hero sources + thumbnail (same idea as timeline image pool). */
const projectImagePool: string[] = [];
for (const h of heroImages) {
  if (
    h.src &&
    !isVideoAssetPath(h.src) &&
    !projectImagePool.includes(h.src)
  ) {
    projectImagePool.push(h.src);
  }
  if (h.splitImages) {
    for (const splitImg of h.splitImages) {
      if (
        splitImg &&
        !isVideoAssetPath(splitImg) &&
        !projectImagePool.includes(splitImg)
      ) {
        projectImagePool.push(splitImg);
      }
    }
  }
}
const thumbPrefixed =
  withBasePublicPath(project.data.thumbnail, baseUrl) ?? project.data.thumbnail;
if (
  thumbPrefixed &&
  !isVideoAssetPath(thumbPrefixed) &&
  !projectImagePool.includes(thumbPrefixed)
) {
  projectImagePool.push(thumbPrefixed);
}
---

<BaseLayout title={`${headline} — joy·object`} description={subtitle}>
  <div class="project">
    <header class="project__header">
      <a href={import.meta.env.BASE_URL} class="type-logo home__logo" style="text-decoration:none;color:var(--gray-900);">
        joy<span class="home__logo-dot"></span>object
      </a>
      <nav class="nav-prevnext">
        <a href={`${import.meta.env.BASE_URL}projects/${prevProject.id}`} class="nav-prevnext__item">
          <svg class="nav-prevnext__arrow nav-prevnext__arrow--prev" width="20" height="20" viewBox="0 0 20 20" fill="none">
            <path d="M4 10H16M16 10L11 5M16 10L11 15" stroke="#1c1c1c" stroke-width="1.5"/>
          </svg>
          <span class="type-nav">PREV</span>
        </a>
        <a href={`${import.meta.env.BASE_URL}projects/${nextProject.id}`} class="nav-prevnext__item">
          <span class="type-nav">NEXT</span>
          <svg class="nav-prevnext__arrow" width="20" height="20" viewBox="0 0 20 20" fill="none">
            <path d="M4 10H16M16 10L11 5M16 10L11 15" stroke="#1c1c1c" stroke-width="1.5"/>
          </svg>
        </a>
      </nav>
    </header>

    <div class="project__hero-bands">
    <div class="project__top">
      <div class="project__title-group">
        <h1 class="project__title">{headline}</h1>
        <p class="project__subtitle">{subtitle}</p>
      </div>
    </div>
    </div>

    <div class="project__hero-lower">
      <div class="project__intro">
        {introduction && (
          <div class="project__intro-content">
            <p class="project__intro-text">{introduction}</p>
          </div>
        )}
        <div class="project__intro-meta">
          <div class="project__intro-meta-block project__intro-meta-block--primary">
            <p class="project__meta-year">{year}</p>
            {urlHref && (
              <p class="project__meta-url-line">
                <a class="project__meta-url-link" href={urlHref} rel="noopener noreferrer" target="_blank">
                  {urlTrimmed}
                </a>
              </p>
            )}
          </div>
          <div class="project__intro-meta-block">
            <div class="type-tiny project__intro-meta-label">Industry</div>
            <p class="project__meta-category">{displayCategory}</p>
          </div>
          <div class="project__intro-meta-block">
            <div class="type-tiny project__intro-meta-label">What I did</div>
            <p class="type-tiny project__meta-roles">{tags.join(' / ')}</p>
          </div>
        </div>
      </div>
      {heroImages && heroImages.length > 0 && (
        <div class="project__collage">
          {heroImages.map((img) => {
            let cyclePoolJson: string | undefined;
            if (img.src && img.cycleProjectPool && projectImagePool.length >= 2) {
              cyclePoolJson = JSON.stringify(projectImagePool);
            } else if (img.src && img.cycleImages?.length) {
              const pool = [img.src, ...img.cycleImages].filter(
                (u, i, a) => a.indexOf(u) === i,
              );
              if (pool.length >= 2) cyclePoolJson = JSON.stringify(pool);
            }
            return (
            <div class={`project__collage-item project__collage-item--${img.size}`}>
              {img.size === 'small-split' && img.splitImages && img.splitImages.length === 2 ? (
                <div class="project__collage-item-split-container">
                  <div class="project__collage-item-media">
                    {isVideoAssetPath(img.splitImages[0]) ? (
                      <video src={img.splitImages[0]} muted loop playsinline autoplay aria-label={headline} />
                    ) : (
                      <img src={img.splitImages[0]} alt={headline} loading="lazy" />
                    )}
                  </div>
                  <div class="project__collage-item-media">
                    {isVideoAssetPath(img.splitImages[1]) ? (
                      <video src={img.splitImages[1]} muted loop playsinline autoplay aria-label={headline} />
                    ) : (
                      <img src={img.splitImages[1]} alt={headline} loading="lazy" />
                    )}
                  </div>
                </div>
              ) : (
                <div class="project__collage-item-media">
                  {img.src &&
                    (isVideoAssetPath(img.src) ? (
                    <video
                      src={img.src}
                      muted
                      loop
                      playsinline
                      autoplay
                      aria-label={img.caption || headline}
                    />
                  ) : (
                    <img
                      src={img.src}
                      alt={img.caption ? '' : headline}
                      loading="lazy"
                      data-cycle={cyclePoolJson}
                    />
                  ))}
                  {img.videoEmbed && (
                    <div
                      class:list={[
                        'project__collage-embed',
                        'project__embed',
                        { 'project__embed--vertical': img.embedVertical },
                      ]}
                    >
                      <iframe
                        src={img.videoEmbed}
                        title={img.caption || headline}
                        width={img.embedVertical ? 240 : 640}
                        height={img.embedVertical ? 426 : 360}
                        frameborder="0"
                        allow="autoplay; fullscreen; picture-in-picture; clipboard-write; encrypted-media; web-share"
                        referrerpolicy="strict-origin-when-cross-origin"
                        loading="lazy"
                        allowfullscreen
                      />
                    </div>
                  )}
                  {img.overlayVideo && (
                    <video
                      class="project__collage-overlay-video"
                      src={img.overlayVideo}
                      style={{ width: img.overlayVideoWidth || '60%' }}
                      muted
                      loop
                      playsinline
                      autoplay
                      aria-label={img.caption || headline}
                    />
                  )}
                </div>
              )}
              {img.caption && (
                <p class="project__image-caption">{img.caption}</p>
              )}
            </div>
            );
          })}
        </div>
      )}
    </div>

    <!-- Content -->
    <div class="project__content">
      <Content />
    </div>

    <!-- Footer -->
    <div class="project__footer">
      <div class="project__footer-title">
        <a href={import.meta.env.BASE_URL} style="text-decoration:none;">All projects</a>
      </div>
      <nav class="nav-prevnext">
        <a href={`${import.meta.env.BASE_URL}projects/${prevProject.id}`} class="nav-prevnext__item">
          <svg class="nav-prevnext__arrow nav-prevnext__arrow--prev" width="20" height="20" viewBox="0 0 20 20" fill="none">
            <path d="M4 10H16M16 10L11 5M16 10L11 15" stroke="#1c1c1c" stroke-width="1.5"/>
          </svg>
          <span class="type-nav">PREV</span>
        </a>
        <a href={`${import.meta.env.BASE_URL}projects/${nextProject.id}`} class="nav-prevnext__item">
          <span class="type-nav">NEXT</span>
          <svg class="nav-prevnext__arrow" width="20" height="20" viewBox="0 0 20 20" fill="none">
            <path d="M4 10H16M16 10L11 5M16 10L11 15" stroke="#1c1c1c" stroke-width="1.5"/>
          </svg>
        </a>
      </nav>
    </div>
  </div>
</BaseLayout>

<script define:vars={{ baseUrl: import.meta.env.BASE_URL }}>
  document.addEventListener("DOMContentLoaded", () => {
    // Prefix all images and videos for subpath compatibility
    const prefix = baseUrl.replace(/\/$/, "");
    const normalizeAssetPath = (path) => {
      if (!path) return path;
      if (!prefix) return path;
      if (path.startsWith(`${prefix}/`)) return path;
      if (path.startsWith("/images/")) return prefix + path;
      return path;
    };
    if (prefix) {
      document.querySelectorAll('img, video, source').forEach(el => {
        const src = el.getAttribute('src');
        if (src && src.startsWith('/images/')) {
          el.setAttribute('src', prefix + src);
        }
      });
    }

    const CYCLE_MS = 280;

    document.querySelectorAll("[data-cycle]").forEach((img) => {
      const raw = img.dataset.cycle || "";
      let pool;
      try {
        pool = JSON.parse(raw);
      } catch {
        pool = raw.split(",").map((s) => s.trim());
      }
      pool = pool.map((src) => normalizeAssetPath(src)).filter(Boolean);
      if (!pool.length) return;

      const originalSrc = normalizeAssetPath(img.getAttribute("src") || "");
      if (!pool.includes(originalSrc)) pool.unshift(originalSrc);
      if (pool.length < 2) return;

      pool.forEach((src) => {
        const preload = new Image();
        preload.src = src;
      });

      const wrap = img.closest(".project__collage-item-media, figure") || img;
      let idx = pool.indexOf(originalSrc);
      if (idx === -1) idx = 0;

      setInterval(() => {
        idx = (idx + 1) % pool.length;
        img.src = pool[idx];
      }, CYCLE_MS);

      wrap.classList.add("is-auto-cycling");
    });
  });
</script>

<style>
  /* ── 4-column content grid ── */
  .project__content {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    column-gap: 24px;
    width: 100%;
  }

  /* Text defaults: 1-column width at column 1 */
  .project__content :global(h2) {
    grid-column: 1 / span 1;
    font-family: var(--font-display);
    font-size: var(--project-fluid-h2);
    font-weight: 400;
    line-height: var(--project-fluid-intro-lh);
    letter-spacing: 0.4px;
    text-transform: uppercase;
    color: var(--gray-900);
    margin-top: clamp(32px, 4vw + 18px, 48px);
    margin-bottom: 12px;
  }
  .project__content :global(h2 + *) {
    margin-top: clamp(32px, 4vw + 18px, 48px);
  }

  .project__content :global(h3) {
    grid-column: 1 / span 1;
    font-family: var(--font-display);
    font-size: var(--project-fluid-h3);
    font-weight: 400;
    line-height: var(--project-fluid-intro-lh);
    color: var(--gray-900);
    letter-spacing: 0;
    text-transform: none;
    margin-top: clamp(24px, 2.5vw + 14px, 32px);
    margin-bottom: 12px;
  }
  .project__content :global(h3 + *) {
    margin-top: clamp(24px, 2.5vw + 14px, 32px);
  }

  .project__content :global(p) {
    grid-column: 2 / span 2;
    font-family: var(--font-body);
    font-size: var(--project-fluid-body);
    line-height: var(--project-fluid-intro-lh);
    margin-bottom: 16px;
  }

  /* Same scale as hero `.project__intro-text`; Source Serif 4 (body stack) */
  .project__content :global(p.project__intro-text) {
    font-family: var(--font-body);
    font-size: var(--project-fluid-intro);
    line-height: var(--project-fluid-intro-lh);
  }

  /* Markdown blockquote (>) — pull quote: Pantasia, centred, intro scale */
  .project__content :global(blockquote) {
    grid-column: 2 / span 2;
    margin: clamp(24px, 3vw, 40px) 0;
    padding: 0;
    border: none;
    font-family: var(--font-display);
    font-size: var(--project-fluid-intro);
    line-height: var(--project-fluid-intro-lh);
    font-style: normal;
    font-weight: 400;
    text-align: center;
    color: var(--gray-900);
  }

  .project__content :global(blockquote p) {
    font-family: inherit;
    font-size: inherit;
    line-height: inherit;
    font-style: inherit;
    font-weight: inherit;
    text-align: center;
    margin-bottom: 12px;
  }

  .project__content :global(blockquote p:last-child) {
    margin-bottom: 0;
  }

  .project__content :global(ul),
  .project__content :global(ol) {
    grid-column: 2 / span 2;
    font-family: var(--font-body);
    font-size: var(--project-fluid-body);
    line-height: var(--project-fluid-intro-lh);
    margin-bottom: 16px;
    padding-left: 20px;
    list-style: disc;
  }

  .project__content :global(li) {
    margin-bottom: 8px;
  }

  /* Markdown inline bold: **text** or <strong> */
  .project__content :global(strong),
  .project__content :global(b) {
    font-family: var(--font-strong);
    font-weight: 700;
  }

  /* ── Images & figures ── */

  .project__content :global(figure) {
    grid-column: 2 / span 2;
    margin: 24px 0;
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 8px;
    min-width: 0;
    overflow: visible;
  }

  .project__content :global(figure.project__figure--full) {
    grid-column: 1 / -1;
  }

  .project__content :global(figure img) {
    width: 100%;
    border-radius: 4px;
    margin: 0;
    display: block;
    flex-shrink: 0;
  }

  .project__content :global(figcaption) {
    font-family: var(--font-mono);
    font-size: var(--project-fluid-label);
    line-height: var(--project-fluid-label-lh);
    letter-spacing: 0.4px;
    text-transform: uppercase;
    text-align: center;
    color: var(--gray-600);
    margin-top: 0;
    flex: 0 0 auto;
    width: 100%;
    overflow-wrap: anywhere;
  }

  .project__content :global(p > img) {
    width: 100%;
    border-radius: 4px;
    margin: 24px 0;
  }

  /* Legacy collage wrapper (manually written HTML in markdown) */
  .project__content :global(.project__content-collage) {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: repeat(var(--collage-cols, 2), minmax(0, 1fr));
    column-gap: 24px;
    row-gap: 16px;
    margin: 24px 0;
    width: 100%;
  }

  .project__content :global(.project__content-collage figure) {
    grid-column: auto;
    margin: 0;
  }

  .project__content :global(.project__content-collage p) {
    grid-column: auto;
    margin: 0;
  }

  .project__content :global(.project__content-collage p > img) {
    grid-column: auto;
    margin: 0;
    width: 100%;
    border-radius: 4px;
    display: block;
  }

  .project__content :global(.project__collage) {
    grid-column: 1 / -1;
    margin: 24px 0;
    width: 100%;
  }

  /* ── Embeds ── */

  .project__content :global(.project__embed) {
    grid-column: 2 / span 2;
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    margin: 24px 0;
    border-radius: 4px;
    overflow: hidden;
    background: var(--gray-900);
  }

  .project__content :global(figure .project__embed) {
    grid-column: unset;
    margin: 0;
  }

  .project__content :global(.project__embed--vertical) {
    width: min(320px, 100%);
    aspect-ratio: 9 / 16;
    margin-left: auto;
    margin-right: auto;
  }

  .project__content :global(.project__embed iframe) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: none;
  }

  /* ── XXL: wider gutters & spacing ── */
  @media (min-width: 1400px) {
    .project__content {
      column-gap: 32px;
    }

    .project__content :global(figure) {
      margin: 32px 0;
    }

    .project__content :global(.project__embed) {
      margin: 32px 0;
    }

    .project__content :global(.project__content-collage) {
      column-gap: 32px;
      row-gap: 20px;
      margin: 32px 0;
    }
  }

  /* ── Tablet: 4-col → 2-col ── */
  @media (max-width: 1024px) {
    .project__content {
      grid-template-columns: repeat(2, 1fr);
    }

    .project__content :global(h2),
    .project__content :global(h3),
    .project__content :global(p),
    .project__content :global(ul),
    .project__content :global(ol),
    .project__content :global(blockquote),
    .project__content :global(figure) {
      grid-column: 1 / -1 !important;
    }

    .project__content :global(.project__embed) {
      grid-column: 1 / -1;
    }
  }

  /* ── Mobile: single column (block) ── */
  @media (max-width: 768px) {
    .project__content {
      display: block;
    }

    .project__content :global(.project__content-collage) {
      grid-template-columns: 1fr;
      margin: 16px 0;
    }
    .project__content :global(h2) {
      margin-top: 32px;
    }

    .project__content :global(figure) {
      grid-column: unset !important;
      margin: 16px 0;
    }

    .project__content :global(p > img) {
      margin: 16px 0;
    }

    .project__content :global(.project__embed) {
      margin: 16px 0;
    }

    .project__content :global(.project__embed--vertical) {
      width: 100%;
    }
  }
</style>
