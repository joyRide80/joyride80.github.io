---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import { getCollection } from "astro:content";
import { compareProjectCollectionEntries } from "../lib/projectYear";
import { withBasePublicPath } from "../lib/withBasePublicPath";

const projects = (await getCollection("projects")).sort(
  compareProjectCollectionEntries,
);
const baseUrl = import.meta.env.BASE_URL;
---

<BaseLayout navActive="work">
  <div class="home" id="home">
    <!-- Header -->
    <Header currentPage="work" variant="home" />

    <!-- Bio text -->
    <div class="home__bio" id="home-bio">
      <p class="home__bio-text">
        Hi, I'm Joy — a product designer based in Oslo. With a decade of experience across digital products, I focus on making complex technology feel simple and human. Currently leading design at Skalar and co-founding Megalearn, an AI-powered learning game. Previously at Kahoot! <a
          href={`${import.meta.env.BASE_URL}about/`}
          style="text-decoration: none; color: var(--gray-600);"
          >More about me</a
        >
      </p>
      <div class="home__cta">
        <a href="mailto:joyleelawat@gmail.com" class="btn-dark" id="btn-say-hi">
          <svg
            width="20"
            height="20"
            viewBox="0 0 20 20"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M4 10H16M16 10L11 5M16 10L11 15"
              stroke="white"
              stroke-width="1.5"></path>
          </svg>
          let's talk
        </a>
      </div>
    </div>

    <!-- Intro Slogan Overlay -->
    <div class="intro-slogan" id="intro-slogan" aria-hidden="true">
      <p class="intro-slogan__text" id="intro-slogan-text">DESIGNING WITH CODE, BUILDING WITH PURPOSE.</p>
    </div>

    <!-- Cloud View -->
    <div class="cloud" id="cloud-view">
      <div class="cloud__canvas" id="cloud-canvas">
        <!-- Project images rendered by JS -->
      </div>
    </div>

    <!-- Slogan (Figma node 2110:481) -->
    <div class="slogan" id="slogan">
      <span class="slogan__paren slogan__paren--left">(</span>
      <span class="slogan__text" id="slogan-text">DESIGNING WITH CODE,BUILDING WITH PURPOSE.</span>
      <span class="slogan__paren slogan__paren--right">)</span>
    </div>

    <!-- Timeline View -->
    <div class="timeline" id="timeline-view">
      <div class="timeline__track" id="timeline-track">
        <!-- Rendered by JS -->
      </div>
    </div>

    <!-- Project caption (shared between views; Figma node 2110:478) -->
    <div class="project-overlay-anchor" aria-live="polite" aria-atomic="true">
      <div class="project-overlay" id="project-overlay">
        <div class="project-overlay__title" id="overlay-title"></div>
        <p class="project-overlay__subtitle" id="overlay-subtitle"></p>
      </div>
    </div>

    <!-- Switch -->
    <div class="home__switch">
      <div class="switch" id="view-switch">
        <span class="switch__label" data-view="cloud">Cloud</span>
        <div class="switch__track" id="switch-track" data-active="cloud">
          <div class="switch__thumb"></div>
        </div>
        <span class="switch__label" data-view="timeline">Timeline</span>
      </div>
    </div>
  </div>

  <script
    define:vars={{
      projectsData: projects.map((p) => ({
        slug: p.id,
        title: p.data.title,
        headline: p.data.headline,
        subtitle: p.data.subtitle,
        year: p.data.year,
        url: p.data.url || "",
        category: p.data.category,
        order: p.data.order,
        thumbnail: p.data.thumbnail
          ? withBasePublicPath(p.data.thumbnail, baseUrl) ?? p.data.thumbnail
          : "",
        timelineImage: p.data.timelineImage,
        timelineAspect: p.data.timelineAspect,
        timelineCycle: p.data.timelineCycle,
        timelineVideoEmbed: p.data.timelineVideoEmbed,
        timelineVideoPoster: p.data.timelineVideoPoster
          ? withBasePublicPath(p.data.timelineVideoPoster, baseUrl) ??
            p.data.timelineVideoPoster
          : "",
        heroImages:
          p.data.heroImages?.map((img) => ({
            ...img,
            src: withBasePublicPath(img.src, baseUrl) ?? img.src,
          })) || [],
      })),
      baseUrl,
    }}
  >
    window.__PROJECTS__ = projectsData;
    window.__BASE_URL__ = baseUrl;
  </script>
  <script src="../scripts/cloud.js"></script>
</BaseLayout>

<style>
  /* Hide page chrome until GSAP reveals it — prevents flash on slow connections */
  :global(#site-logo),
  :global(#main-nav),
  :global(#home-bio),
  :global(.home__switch),
  :global(.global-contact),
  :global(#slogan) {
    opacity: 0;
  }
</style>
