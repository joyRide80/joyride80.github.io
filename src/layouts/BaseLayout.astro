---
import MobileNav from "../components/MobileNav.astro";

interface Props {
  title?: string;
  description?: string;
  navActive?: "work" | "about";
}

const {
  title = "joy·object — Product Designer & Creative Technologist",
  description = "Joy is an Oslo-based product designer and creative technologist with 17+ years of experience building AI-native products that feel intuitive, playful, and genuinely useful.",
  navActive,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <!-- Preload critical fonts -->
    <link
      rel="preload"
      href={`${import.meta.env.BASE_URL.replace(/\/$/, "")}/fonts/Pantasia-Regular.woff2`}
      as="font"
      type="font/woff2"
      crossorigin
    />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@400;500&family=Source+Sans+3:wght@700&family=Source+Serif+4:opsz,wght@8..60,200..900&family=Instrument+Serif&family=Tiny5&display=swap"
      rel="stylesheet"
    />

    <!-- Favicon (ico first — many clients still probe /favicon.ico at origin; layout + dev middleware keep base correct) -->
    <link rel="icon" href={`${import.meta.env.BASE_URL}favicon.ico`} sizes="32x32" />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
  </head>
  <body>
    <MobileNav active={navActive ?? null} />
    <slot />

    <!-- Contact Drawer -->
    <div class="contact-drawer" id="contact-drawer">
      <div class="contact-drawer__label">Resources</div>
      <div class="contact-drawer__links">
        <a
          href="https://x.com/joyobject"
          target="_blank"
          rel="noopener"
          class="contact-drawer__link">Twitter / X</a
        >
        <a
          href="https://github.com/joyRide80"
          target="_blank"
          rel="noopener"
          class="contact-drawer__link">Github</a
        >
        <a
          href="https://linkedin.com/in/nareerat"
          target="_blank"
          rel="noopener"
          class="contact-drawer__link">LinkedIn</a
        >
        <a href="mailto:joyleelawat@gmail.com" class="contact-drawer__link"
          >Email</a
        >
      </div>
    </div>

    <!-- Global Get in touch button (hidden on small screens — see mobile nav) -->
    <div class="global-contact">
      <button type="button" class="btn-outline" data-open-contact-drawer>
        Get in touch
      </button>
    </div>

    <script src="../scripts/contact.js"></script>
    <script src="../scripts/mobile-nav.js"></script>
  </body>
</html>

<style is:global>
  @import "../styles/global.css";
</style>

<script define:vars={{ baseUrl: import.meta.env.BASE_URL.replace(/\/$/, "") }}>
  // Dynamically inject @font-face for portability across subpaths/domains
  const style = document.createElement('style');
  const fontPath = baseUrl + "/fonts/Pantasia-Regular.woff2";
  style.textContent = `
    @font-face {
      font-family: "Pantasia";
      src: url("` + fontPath + `") format("woff2");
      font-weight: 400;
      font-style: normal;
      font-display: swap;
    }
  `;
  document.head.appendChild(style);
</script>
