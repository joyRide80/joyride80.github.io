---
interface Props {
  currentPage?: 'work' | 'about';
  showNav?: boolean;
  variant?: 'home' | 'project' | 'about';
}

const { currentPage, showNav = true, variant = 'home' } = Astro.props;
---

<header class={`header header--${variant}`}>
  <a href={import.meta.env.BASE_URL} class="home__logo type-logo" id="site-logo">
    joy<span class="home__logo-dot"></span>object
  </a>
  
  {variant === 'project' && (
    <slot name="nav-prevnext" />
  )}
</header>

{showNav && variant !== 'project' && (
  <nav class="home__nav" id="main-nav">
    <a href={import.meta.env.BASE_URL} class={`btn-light ${currentPage === 'work' ? 'is-active' : ''}`}>
      Work
      {currentPage === 'work' && <span style="display:inline-flex;align-items:center;justify-content:center;width:20px;height:20px;"><span style="width:4px;height:4px;background:var(--gray-900);border-radius:50%;display:block;"></span></span>}
    </a>
    <a href={`${import.meta.env.BASE_URL}about/`} class={`btn-light ${currentPage === 'about' ? 'is-active' : ''}`}>
      About
      {currentPage === 'about' && <span style="display:inline-flex;align-items:center;justify-content:center;width:20px;height:20px;"><span style="width:4px;height:4px;background:var(--gray-900);border-radius:50%;display:block;"></span></span>}
    </a>
  </nav>
)}

<style>
  .header {
    position: relative;
    z-index: 10;
  }

  .header--home {
    position: absolute;
    top: 20px;
    left: var(--page-padding);
  }

  .header--project,
  .header--about {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    padding: 20px var(--page-padding);
  }

  .home__logo {
    text-decoration: none;
    color: var(--gray-900);
  }

  .is-active {
    position: relative;
  }
</style>
